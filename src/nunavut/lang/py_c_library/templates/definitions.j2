{%- for f in t.fields_except_padding %}
             nanobind::arg("{{ f.name }}").none(){%- if not loop.last %},{%- endif -%}
{%- endfor %}
         )
{%- for f in t.fields_except_padding -%}
    {%- if f.data_type is PrimitiveType %}
        .def_rw("{{ f.name }}", &{{ t | full_reference_name }}::{{ f.name | id }}) // primitive type
    {%- elif f.data_type is CompositeType %}
        .def_rw("{{ f.name }}", &{{ t | full_reference_name }}::{{ f.name | id }}) // composite type
    {%- elif f.data_type is FixedLengthArrayType -%}
        {%- if f.data_type.element_type is BooleanType %}
        //.def_rw("{{ f.name }}", &{{ t | full_reference_name }}::{{ f.name | id }}_bitpacked_) // fixed-length boolean array
        {%- else %}
