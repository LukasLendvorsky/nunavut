                        return std::nullopt;
                     }) // variable-length stringlike array
        .def_prop_ro_static("{{ f.name }}_CAPACITY", [](nanobind::handle){ return {{ f.data_type.capacity }}; })
            {%- else %}
        .def_prop_ro("{{ f.name }}",
                     []({{ t | full_reference_name }} &self) -> std::optional<std::vector<{{ _type_from_field(f.data_type.element_type) }}>>
                     {
                        if ({{ t | full_reference_name }}_is_{{ f.name }}_(&self)){
                            return get_variable_array(self.{{ f.name | id }});
