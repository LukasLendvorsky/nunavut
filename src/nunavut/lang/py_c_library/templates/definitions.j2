{% macro _define_export_union(t) %}
    {%- for f in t.fields_except_padding -%}
        {%- if f.data_type is PrimitiveType %}
        .def("__init__", // overloaded constructor for union with primitive type element
             []({{ t | full_reference_name }}* self,
                {{ f.data_type | type_from_primitive }} {{ f.name | id }}){
                {{ t | full_reference_name }}_select_{{ f.name }}_(self);
                    self->{{ f.name | id }} = {{ f.name | id }};
                },
                nanobind::arg("{{ f.name }}"))
        {%- elif f.data_type is CompositeType %}
        .def("__init__", // overloaded constructor for union with composite type element
             []({{ t | full_reference_name }}* self,
                {{ f.data_type | full_reference_name }} &{{ f.name | id }}){
                {{ t | full_reference_name }}_select_{{ f.name }}_(self);
                    self->{{ f.name | id }} = {{ f.name | id }};
                },
                nanobind::arg("{{ f.name }}"))
        {%- elif f.data_type is FixedLengthArrayType %}
        .def("__init__", // overloaded constructor for union with FixedLengthArrayType
            {%- if f.data_type.element_type.bit_length == 8 %}
             []({{ t | full_reference_name }}* self,
                const nanobind::bytes &{{ f.name | id }}) {
                    {{ t | full_reference_name }}_select_{{ f.name }}_(self);
                    set_fixed_bytes_array(self->{{ f.name | id }}, {{ f.data_type.capacity }}, *{{ f.name | id }});
                },
                nanobind::arg("{{ f.name }}"))
            {%- else %}
              []({{ t | full_reference_name }}* self,
                const std::array<{{_type_from_field(f.data_type.element_type)}}, {{f.data_type.capacity}}> &{{ f.name | id }}) {
                    {{ t | full_reference_name }}_select_{{ f.name }}_(self);
                    {%- if f.data_type.element_type is BooleanType %}
                    set_fixed_bitpacked_array(self->{{ f.name | id }}_bitpacked_, {{ f.name | id }});
                    {%- else %}
                    set_fixed_array(self->{{ f.name | id }}, {{ f.name | id }});
                    {%- endif %}
                },
                nanobind::arg("{{ f.name }}"))
            {%- endif -%}
        {%- elif f.data_type is VariableLengthArrayType %}
            {%- if f.data_type.string_like %}
        .def("__init__", // string-like variable-length array
              []({{ t | full_reference_name }}* self,
                std::variant<nanobind::bytes, nanobind::str, nanobind::typed<nanobind::list, int> , std::nullptr_t> {{ f.name | id }}) {
                    {{ t | full_reference_name }}_select_{{ f.name }}_(self);
                    set_variable_stringlike_array(self->{{ f.name | id }}, {{ f.name | id }});
                },
                nanobind::arg("{{ f.name }}"))
            {% else %}
        .def("__init__", // variable-length array
              []({{ t | full_reference_name }}* self,
                std::optional<std::vector<{{_type_from_field(f.data_type.element_type)}}>> {{ f.name | id }}){
                    {{ t | full_reference_name }}_select_{{ f.name }}_(self);
                {%- if f.data_type.element_type is BooleanType %}
                    set_variable_bitpacked_array(self->{{ f.name | id }}, *{{ f.name | id }});
                {%- else %}
                    set_variable_array(self->{{ f.name | id }}, *{{ f.name | id }});

                {%- endif %}
                },
                nanobind::arg("{{ f.name }}"))
            {% endif %}
        {%- else %}
            {%- assert False %}{# Not a valid field type. #}
        {%- endif -%}
    {%- endfor %}
        // getters for union type
    {%- for f in t.fields_except_padding -%}
        {%- if f.data_type is PrimitiveType %}
        .def_prop_ro("{{ f.name }}", []({{ t | full_reference_name }} &self) -> std::optional<{{ f.data_type | type_from_primitive }} > {
