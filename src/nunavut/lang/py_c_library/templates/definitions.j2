                    }) // fixed-length array
        .def_prop_ro_static("{{ f.name }}_CAPACITY", [](nanobind::handle){ return {{ f.data_type.capacity }}; })
            {%- endif -%}
        {%- elif f.data_type is VariableLengthArrayType -%}
            {%- if f.data_type.element_type is BooleanType %}
        .def_prop_ro("{{ f.name }}",
                     []({{ t | full_reference_name }} &self) -> std::optional<std::vector<bool>>
                     {
                        if ({{ t | full_reference_name }}_is_{{ f.name }}_(&self)){
                            return get_variable_bitpacked_array(self.{{ f.name | id }});
