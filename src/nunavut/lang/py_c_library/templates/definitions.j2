{% macro _repr_print_value(t, f) -%}
       {%- if f.data_type is PrimitiveType and f.data_type.bit_length <= 8 %}
    ss << (int)self.{{ f.name | id }}; // force print as integer, not char
       {%- elif f.data_type is PrimitiveType %}
    ss << self.{{ f.name | id }};
       {%- elif f.data_type is CompositeType %}
    ss << {{ f.data_type | full_reference_name }}_repr(self.{{ f.name | id }});
       {%- elif f.data_type is FixedLengthArrayType %}
           {%- if f.data_type.element_type is BooleanType %}
    ss << "[";
    for (size_t i = 0; i < {{ f.data_type.capacity }}; ++i) {
        if (i > 0) ss << ", ";
        ss << ((self.{{ f.name | id }}_bitpacked_[i / 8U] & (1U << (i % 8U))) ? "true" : "false");
    }
    ss << "]";
           {%- else %}
    ss << "[";
    for (size_t i = 0; i < {{ f.data_type.capacity }}; ++i) {
        if (i > 0) ss << ", ";
               {%- if f.data_type.element_type is CompositeType %}
        ss << {{ f.data_type.element_type | full_reference_name }}_repr(self.{{ f.name | id }}[i]);
               {%- elif f.data_type.element_type is PrimitiveType and f.data_type.element_type.bit_length <= 8 %}
        ss << (int)self.{{ f.name | id }}[i];
               {%- else %}
        ss << self.{{ f.name | id }}[i];
               {%- endif %}
    }
    ss << "]";
           {%- endif %}
       {%- elif f.data_type is VariableLengthArrayType %}
           {%- if f.data_type.string_like %}
    ss << "\"";
    for (size_t i = 0; i < self.{{ f.name | id }}.count && i < {{ f.data_type.capacity }}U; ++i) {
        uint8_t c = self.{{ f.name | id }}.elements[i];
        if (c >= 0x20 && c <= 0x7E) {
            ss << (char)c;
        } else {
            ss << "\\x" << std::hex << std::setfill('0') << std::setw(2) << (int)c << std::dec;
        }
    }
    ss << "\"";
           {%- elif f.data_type.element_type is BooleanType %}
    ss << "[";
    for (size_t i = 0; i < self.{{ f.name | id }}.count && i < {{ f.data_type.capacity }}U; ++i) {
        if (i > 0) ss << ", ";
        ss << ((self.{{ f.name | id }}.bitpacked[i / 8U] & (1U << (i % 8U))) ? "true" : "false");
    }
    ss << "]";
           {%- else %}
    ss << "[";
    for (size_t i = 0; i < self.{{ f.name | id }}.count && i < {{ f.data_type.capacity }}U; ++i) {
        if (i > 0) ss << ", ";
               {%- if f.data_type.element_type is CompositeType %}
        ss << {{ f.data_type.element_type | full_reference_name }}_repr(self.{{ f.name | id }}.elements[i]);
               {%- elif f.data_type.element_type is PrimitiveType and f.data_type.element_type.bit_length <= 8 %}
        ss << (int)self.{{ f.name | id }}.elements[i];
               {%- else %}
        ss << self.{{ f.name | id }}.elements[i];
               {%- endif %}
    }
    ss << "]";
           {%- endif %}
       {%- else -%}
         {% assert False %}{# Not a valid field type. #}
       {%- endif -%}
{%- endmacro %}

std::string  {{ t | full_reference_name }}_repr(const {{ t | full_reference_name }} &self)
{
    std::stringstream ss;
    ss << "{{ t | short_reference_name }}(";
{%- if t.inner_type is UnionType %}
    {%- for f in t.fields_except_padding %}
    {{ "} else " if not loop.first else "" }}if ({{ t | full_reference_name }}_is_{{ f.name }}_(&self)) {
        ss << "{{ f.name }}=";
        {{ _repr_print_value(t, f) }}
    {%- endfor %}
    }
{%- else %}
    {%- for f in t.fields_except_padding %}
    ss << "{{ f.name }}=";
    {{- _repr_print_value(t, f) }}
       {%- if not loop.last %}
    ss << ", ";
       {%- endif %}
    {%- endfor %}
{%- endif %}
    ss << ")";
    return ss.str();
}

void export_type_{{ t | full_reference_name }}(nanobind::module_ &m)
{
    nanobind::class_<{{ t | full_reference_name }}>(m, "{{ t | short_reference_name }}")
{%- if t.inner_type is UnionType -%}
    {{- _define_export_union(t) -}}
{%- elif t.inner_type is StructureType -%}
    {{- _define_export_struct(t) -}}
{%- endif %}
        .def("__serialize__", &python_serialize<{{ t | full_reference_name }}, {{ t | full_reference_name }}_SERIALIZATION_BUFFER_SIZE_BYTES_, {{ t | full_reference_name }}_serialize_>)
        .def_static("__deserialize__", &python_deserialize<{{ t | full_reference_name }}, {{ t | full_reference_name }}_deserialize_>)
        {%- for constant in t.constants %}
        .def_prop_ro_static("{{ constant.name }}", [](nanobind::handle){return {{ constant | constant_value }};})
        {%- endfor %}
        .def_prop_ro_static("__EXTENT_BYTES__", [](nanobind::handle){return {{ t | full_reference_name }}_EXTENT_BYTES_;})
        {% if t.has_fixed_port_id %}
        .def_prop_ro_static("__FIXED_PORT_ID__", [](nanobind::handle){return {{ t | full_reference_name }}_FIXED_PORT_ID_;})
        {% endif %}
        .def_prop_ro_static("__DSDL_NAME__", [](nanobind::handle){return "{{t.full_name}}.{{t.version.major}}.{{t.version.minor}}";})
        .def_ro_static("__ATTRIBUTES__", &{{ t | full_reference_name }}_attributes)
        .def("__repr__", {{ t | full_reference_name }}_repr);
}
{% endmacro %}

