                {{ f.data_type | full_reference_name }} {{ f.name | id }}{%- if not loop.last %},{%- endif %} // CompositeType
    {%- elif f.data_type is FixedLengthArrayType %}
                int {{ f.name | id }}{%- if not loop.last %},{%- endif %} // FixedLengthArrayType
