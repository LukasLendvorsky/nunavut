{% extends "base.j2" -%}
{%- block contents -%}
from typing import TypeAlias

class {{ T|short_reference_name }}:
    Request : TypeAlias = python_dsdls.{{ T | full_reference_name }}.{{ T.request_type | short_reference_name }}
    Response : TypeAlias = python_dsdls.{{ T| full_reference_name }}.{{ T.response_type | short_reference_name }}

    {% if T.has_fixed_port_id %}
    _FIXED_PORT_ID_ : int = {{ T.fixed_port_id|int }}
    {% endif %}
    _DSDL_NAME_ : str = "{{T.full_name}}.{{T.version.major}}.{{T.version.minor}}"

{%- endblock -%}
